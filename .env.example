PGHOST=localhost
PGPORT=5432
PGDATABASE=exclusion_list
PGUSER=postgres
PGPASSWORD=your_password_here

# Local merge testing (Steps 5–6): PostgreSQL must be running on PGHOST:PGPORT.
# Mac dev often uses SSH tunnel PGPORT=15432 → vesta; or run scripts/import_with_db.sh.
# Production merge runs on vesta via bash scripts/deploy_vesta.sh (see deploy/config.sh).

# Django web application (web/)
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Production example: ALLOWED_HOSTS=107.181.241.82,your.domain.com
# CSRF_TRUSTED_ORIGINS=https://your.domain.com
# DEPLOY_SSH_PASSWORD=your-vesta-ssh-password
