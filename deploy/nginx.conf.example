# Nginx site config for Medicaid Exclusion List web app.
# Copy to /etc/nginx/sites-available/exclusion-web and symlink to sites-enabled.

server {
    listen 80;
    server_name your.server.example;

    client_max_body_size 4M;

    location /static/ {
        alias /home/USER/exclusion-list/web/staticfiles/;
    }

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
